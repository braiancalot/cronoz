{
  "name": "cronoz",
  "version": "0.1.0",
  "description": "PWA para gerenciar múltiplos cronômetros",
  "author": "Braian Calot <braian.s.calot@gmail.com>",
  "license": "MIT",
  "keywords": [
    "pwa",
    "timer",
    "stopwatch"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/braiancalot/cronoz"
  },
  "engines": {
    "node": ">=22"
  },
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:check": "prettier --check .",
    "commit": "cz",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "dexie": "^4.3.0",
    "dexie-react-hooks": "^4.2.0",
    "next": "16.1.4",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@serwist/turbopack": "^9.5.6",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "esbuild": "^0.27.4",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "eslint-config-prettier": "^10.1.8",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.1",
    "serwist": "^9.5.6",
    "tailwindcss": "^4",
    "vitest": "^4.1.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
